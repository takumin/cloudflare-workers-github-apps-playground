{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:best-practices",
		"github>aquaproj/aqua-renovate-config#2.10.0"
	],
	"timezone": "Asia/Tokyo",
	"automerge": true,
	"lockFileMaintenance": {
		"enabled": true
	},
	"packageRules": [
		{
			"groupName": "node",
			"matchPackageNames": ["node", "nodejs/node"],
			"versioning": "node"
		},
		{
			"groupName": "pnpm",
			"matchPackageNames": ["pnpm", "pnpm/pnpm"]
		}
	],
	"customManagers": [
		{
			"customType": "regex",
			"managerFilePatterns": ["/(^|\\/)\\.aqua\\.ya?ml$/"],
			"matchStrings": [
				"(?<indentation>\\s*)version:\\s*v?(?<currentValue>\\d+\\.\\d+\\.\\d+)\\s*#\\s*renovate:\\s*datasource=github-releases\\s*depName=nodejs/node"
			],
			"depNameTemplate": "nodejs/node",
			"datasourceTemplate": "github-releases",
			"versioningTemplate": "semver",
			"autoReplaceStringTemplate": "{{{indentation}}}version: {{{prettyNewVersion}}} # renovate: datasource=github-releases depName=nodejs/node"
		}
	]
}
